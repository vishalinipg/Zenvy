# ============================================================
# frontend/.env.example — Environment Variables
# ============================================================
# Copy this to .env for local development.
# On Render, set these in the service's Environment tab.
# ============================================================

# Backend API URL
# Local dev: leave blank or set to http://localhost:8000
# Render:    set to your backend service URL, e.g.:
#            https://zenvy-backend.onrender.com
VITE_API_URL=http://localhost:8000
